# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABCDEF

# Recommended: only allow your Telegram user ID.
# Use @userinfobot to get it. Leave empty only if you understand the risk.
AUTHORIZED_USER_ID=5923714838

# Google Apps Script webhook v2 used to create/append/format sheets.
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/xxx/exec
SHEETS_SECRET_TOKEN=change_me

# Optional: Google Drive folder ID where created Sheets should be moved/saved.
SHEETS_FOLDER_ID=

# Facebook Graph/API crawl settings.
FB_API_VERSION=v25.0
DEFAULT_LIMIT=200
DEFAULT_DELAY_MS=600

# Google Sheets append settings.
EXPORT_CHUNK_SIZE=1000
EXPORT_DELAY_MS=600

# Supported URL formats:
# - Direct post ID: 123456789
# - /posts/ID, /videos/ID, /reel/ID, /photo/ID, /permalink/ID
# - ?v=ID, ?story_fbid=ID&id=OWNER
# - pfbid... text IDs (auto-resolved via HTML scraping)
# - /share/... redirect URLs (auto-followed)
# - Inline options: top 10, --free-limit 200, --max-rows 500

# Auto token extraction via Chromium headless inside Docker.
# Defaults to true. Set to 'false' to disable and require manual update_token.
AUTO_TOKEN_REFRESH=true
CHROME_PAGE_LOAD_TIMEOUT_SECONDS=60
